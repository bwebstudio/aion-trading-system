# ─────────────────────────────────────────────
# AION — Environment Configuration Template
# Copy to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# System
AION_ENVIRONMENT=RESEARCH        # RESEARCH | PRODUCTION
AION_MODE=PAPER                  # PAPER | LIVE
AION_LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# Paths (defaults shown — override if needed)
# AION_DATA_ROOT=data
# AION_RAW_DATA_DIR=data/raw
# AION_NORMALIZED_DATA_DIR=data/normalized
# AION_FEATURES_DATA_DIR=data/features
# AION_SNAPSHOTS_DATA_DIR=data/snapshots
# AION_SAMPLES_DATA_DIR=data/samples

# Timezone
AION_LOCAL_TIMEZONE=Europe/Madrid

# Default symbol for pipeline runs
AION_DEFAULT_SYMBOL=EURUSD

# MetaTrader5 (only needed for live data / execution)
# AION_MT5_LOGIN=12345678
# AION_MT5_PASSWORD=your_password
# AION_MT5_SERVER=ICMarkets-Demo
